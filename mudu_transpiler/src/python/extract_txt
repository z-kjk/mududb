    ///测试visit_call和walk_node调用->没重复
    //单层嵌套
    #[test]
    fn test_nested_call_duplicate_debug() {
        let code = r#"
#mudu_proc#
def main():
    foo(bar())
"#;

        let context = parse_ok(code);

        println!("=== call_dependencies ===");
        for (callee, callers) in &context.call_dependencies {
            println!("{} <- {:?}", callee, callers);
        }

        println!("=== position_call_end ===");
        for (name, positions) in &context.position_call_end {
            println!("{} -> {} times", name, positions.len());
        }

        // bar() 只应该被收集一次
        let bar_positions = context.position_call_end.get("bar").unwrap();
        assert_eq!(bar_positions.len(), 1, "bar() 被重复收集了，实际次数: {}", bar_positions.len());
    }

    //深层嵌套
    #[test]
    fn test_deep_nested_call_duplicate_debug() {
        let code = r#"
#mudu_proc#
def main():
    foo(bar(baz()))
"#;

        let context = parse_ok(code);

        println!("=== position_call_end ===");
        for (name, positions) in &context.position_call_end {
            println!("{} -> {} times", name, positions.len());
        }

        let foo_count = context.position_call_end.get("foo").unwrap().len();
        let bar_count = context.position_call_end.get("bar").unwrap().len();
        let baz_count = context.position_call_end.get("baz").unwrap().len();

        assert_eq!(foo_count, 1, "foo 被重复收集，实际: {}", foo_count);
        assert_eq!(bar_count, 1, "bar 被重复收集，实际: {}", bar_count);
        assert_eq!(baz_count, 1, "baz 被重复收集，实际: {}", baz_count);
    }

    //同级多次调用
    #[test]
    fn test_sibling_calls_should_be_counted_normally() {
        let code = r#"
#mudu_proc#
def main():
    foo(bar(), bar())
"#;

        let context = parse_ok(code);

        println!("=== position_call_end ===");
        for (name, positions) in &context.position_call_end {
            println!("{} -> {} times", name, positions.len());
        }

        let foo_count = context.position_call_end.get("foo").unwrap().len();
        let bar_count = context.position_call_end.get("bar").unwrap().len();

        // foo 出现一次
        assert_eq!(foo_count, 1, "foo 被重复收集，实际: {}", foo_count);
        // bar 在源码里本来就有两个，应该是 2
        assert_eq!(bar_count, 2, "bar 计数不对，实际: {}", bar_count);
    }

}
