// python_parser.rs的
#[cfg(test)]
mod tests_struct {
    use super::*;
    use tree_sitter::Parser;

    fn build_context(code: &str) -> ParseContext {
        ParseContext::new(code.to_string())
    }

    fn parse_ok(code: &str) -> ParseContext {
        let mut context = build_context(code);
        let ret = PythonParser::parse(&mut context);
        assert!(ret.is_ok(), "parse failed: {:?}", ret.err());
        context
    }

    ///进入函数解析判定
    #[test]
    fn test_marked_function_should_enter_mudu_procedure() {
        let code = r#"
#mudu_proc#
def myFunc3(a: int, b: float, c: str, d: bool) -> tuple[int, str, bool, float]:
    return a, c, d, b
"#;
        let context = parse_ok(code);
        assert!(context.mudu_procedure.contains_key("myFunc3"));
    }

    #[test]
    fn test_unmarked_function_should_not_enter_mudu_procedure() {
        let code = r#"
def add(x: int, y: int) -> int:
    return x + y
"#;
        let context = parse_ok(code);
        assert!(!context.mudu_procedure.contains_key("add"));
    }

    #[test]
    fn test_marked_async_function_should_enter_mudu_procedure() {
        let code = r#"
#mudu_proc#
async def fetch(url: str) -> str:
    return url
"#;
        let context = parse_ok(code);
        assert!(context.mudu_procedure.contains_key("fetch"));
    }

    #[test]
    fn test_unmarked_async_function_should_not_enter_mudu_procedure() {
        let code = r#"
async def fetch(url: str) -> str:
    return url
"#;
        let context = parse_ok(code);
        assert!(!context.mudu_procedure.contains_key("fetch"));
    }

    // 只收集带#mudu_proc#注释的
    #[test]
    fn test_only_marked_functions_are_collected() {
        let code = r#"
def normal1():
    pass

#mudu_proc#
def proc1(a: int) -> int:
    return a

def normal2():
    pass
"#;
        let context = parse_ok(code);

        assert!(context.mudu_procedure.contains_key("proc1"));
        assert!(!context.mudu_procedure.contains_key("normal1"));
        assert!(!context.mudu_procedure.contains_key("normal2"));
    }

    #[test]
    fn test_marker_on_previous_line_should_work() {
        let code = r#"#mudu_proc#
def proc():
    return 1
"#;
        let context = parse_ok(code);

        println!(
            "mudu_procedure keys: {:?}",
            context.mudu_procedure.keys().collect::<Vec<_>>()
        );

        assert!(context.mudu_procedure.contains_key("proc"));
    }

    //空格也生效
    #[test]
    fn test_marker_with_blank_line_should_work() {
        let code = r#"#mudu_proc#

def proc():
    return 1
"#;
        let context = parse_ok(code);
        assert!(context.mudu_procedure.contains_key("proc"));
    }

    //非解析函数也可以解析
    #[test]
    fn test_unmarked_function_parse_should_not_panic() {
        let code = r#"
def main():
    foo()
"#;
        let _context = parse_ok(code);
    }

    ///测试AST结构
    // name字段得到函数名
    #[test]
    fn test_expected_child_field_ok() {
        let code = r#"
def add(x: int) -> int:
    return x
"#;
        let mut parser = Parser::new();
        parser.set_language(&python_language()).unwrap();
        let tree = parser.parse(code, None).unwrap();
        let root = tree.root_node();

        let mut cursor = root.walk();
        let func_node = root
            .children(&mut cursor)
            .find(|n| n.kind() == ts_const::ts_kind_name::S_FUNCTION_DEFINITION)
            .unwrap();

        let name_node = expected_child_field(&func_node, ts_const::ts_field_name::NAME);
        assert!(name_node.is_ok());
    }

    //没有name字段
    #[test]
    fn test_expected_child_field_missing_should_fail() {
        let code = r#"
x = 1
"#;
        let mut parser = Parser::new();
        parser.set_language(&python_language()).unwrap();
        let tree = parser.parse(code, None).unwrap();
        let root = tree.root_node();

        let name_node = expected_child_field(&root, ts_const::ts_field_name::NAME);
        assert!(name_node.is_err());
    }

    //有返回类型
    #[test]
    fn test_opt_child_field_ok() {
        let code = r#"
def add(x: int) -> int:
    return x
"#;
        let mut parser = Parser::new();
        parser.set_language(&python_language()).unwrap();
        let tree = parser.parse(code, None).unwrap();
        let root = tree.root_node();

        let mut cursor = root.walk();
        let func_node = root
